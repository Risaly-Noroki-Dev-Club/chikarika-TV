# Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://watchroom:watchroom@localhost:5432/watchroom

# Redis
REDIS_URL=redis://localhost:6379

# Server
SERVER_PORT=2261
SERVER_HOST=0.0.0.0

# Web
PUBLIC_API_URL=http://localhost:2261
PUBLIC_WS_URL=ws://localhost:2261

# Session
SESSION_SECRET=change-me-in-production-use-random-64-chars

# Encryption (for Emby access tokens)
ENCRYPTION_KEY=change-me-in-production-use-random-32-bytes-hex

# CORS
CORS_ORIGIN=http://localhost:2262
